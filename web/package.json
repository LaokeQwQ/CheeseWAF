{
  "name": "cheesewaf-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/verify-build-budget.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -b",
    "test:captcha-contract": "node --test --test-concurrency=1 ../scripts/e2e/captcha-lab/lab-page.test.mjs ../scripts/e2e/captcha-integration/fixture-client.test.mjs",
    "e2e:captcha": "npm run test:captcha-contract && node --test --test-concurrency=1 ../scripts/e2e/captcha-lab/interactions/range.test.mjs ../scripts/e2e/captcha-lab/interactions/surface.test.mjs ../scripts/e2e/captcha-lab/interactions/click.test.mjs ../scripts/e2e/captcha-lab/fixed-harness.test.mjs ../scripts/e2e/captcha-lab/private-harness.test.mjs ../scripts/e2e/captcha-integration/browser-monitor.test.mjs ../scripts/e2e/captcha-integration/runtime.test.mjs ../scripts/e2e/captcha-integration/captcha-lab-flow.test.mjs && node ../scripts/e2e/captcha-integration/run.mjs --profile desktop && node ../scripts/e2e/captcha-lab/run-local.mjs"
  },
  "dependencies": {
    "@arco-design/web-react": "^2.66.15",
    "@province-city-china/area": "^8.5.8",
    "@province-city-china/city": "^8.5.8",
    "@province-city-china/province": "^8.5.8",
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.18.1",
    "china-map-echarts": "^1.0.5",
    "d3-geo": "^3.1.1",
    "i18next": "^26.3.6",
    "lucide-react": "^1.24.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.9",
    "react-router-dom": "^7.18.1",
    "three": "^0.185.1",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/d3-geo": "^3.1.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
