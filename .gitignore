# Local configuration. Commit *.example.yaml templates instead.
configs/*.yaml
!configs/*.example.yaml
!configs/cheesewaf.yaml
configs/versions/

# Operator dumps / support bundles / accidental credential files
cheesewaf-logs-*.zip
*-support-bundle.zip
support-bundle*.zip
*.cookies
*cookie*.txt
*-token.txt
*credential*
*credentials*
!scripts/**/*credential*
forgejo-credential*
*.session
*.secret

# Packed web/backend artifacts that must not ship from a dirty tree
*.tgz
*.tar
*.tar.gz
!docs/**/*.tar.gz
web-dist*.zip
web-dist*.tgz
web-dist*.tar.gz
cheesewaf-web-*.tar.gz
cheesewaf-web-*.tgz
cheesewaf-web-*.zip
cheesewaf-deploy-*.tar.gz
cheesewaf-*-deploy.tar.gz

# Markdown policy (all branches): only public surface docs may be tracked.
# Allowed: README.md, README_CN.md, progress.md (repo root only).
# Everything else (plans, audits, upgrades, agent notes, docs/**, etc.) stays local.
*.md
!/README.md
!/README_CN.md
!/progress.md
*.private.md
*.local.md

# Frontend dependencies and build cache
node_modules/
web/node_modules/
web/dist/
web-dist.tar.gz
web/.vite/
web/coverage/
web/tmp/
web/*.log
web/.env
web/.env.*
!web/.env.example

# Go workspace and dependency cache
go.work
go.work.sum
vendor/
.cache/
.gocache/
.gomodcache/

# Editors and local agent state
.idea/
.vscode/
.claude/
.codex/
.codegraph/
.tmp-playwriter/
.tmp-ui-runtime/
artifacts/
.grok/
.agents/

# OS metadata
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# Agent Eyes local inspector state
