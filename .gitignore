# Local configuration. Commit *.example.yaml templates instead.
configs/*.yaml
!configs/*.example.yaml
!configs/cheesewaf.yaml
configs/versions/

# Markdown policy (all branches): only public surface docs may be tracked.
# Allowed: README.md, README_CN.md, progress.md (repo root only).
# Everything else (plans, audits, upgrades, agent notes, docs/**, etc.) stays local.
*.md
!/README.md
!/README_CN.md
!/progress.md
*.private.md
*.local.md

# Frontend dependencies and build cache
node_modules/
web/node_modules/
web/dist/
web-dist.tar.gz
web/.vite/
web/coverage/
web/tmp/
web/*.log

# Go workspace and dependency cache
go.work
go.work.sum
vendor/
.cache/
.gocache/

# Editors and local agent state
.idea/
.vscode/
.claude/
.codex/
.codegraph/
.tmp-playwriter/
.tmp-ui-runtime/
artifacts/

# OS metadata
.DS_Store
Thumbs.db

# Agent Eyes local inspector state
.code-inspector/
web/.code-inspector/

