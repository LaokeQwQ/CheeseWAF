# Binaries and build output
/bin/
/dist/
/build/
/out/
/output/
/release/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test

# Coverage, profiles, and temporary test artifacts
*.out
coverage.*
*.coverprofile
profile.cov
security-gate*.json
zap-baseline*.html
zap-baseline*.json
sqlmap-output/

# Local runtime state and secrets
.env
.env.*
!.env.example
/data/
/logs/
/run/
**/data/run/
/tmp/
/.tmp/
/temp/
/certs/
*.log
*.key
*.pem
*.crt
*.p12
