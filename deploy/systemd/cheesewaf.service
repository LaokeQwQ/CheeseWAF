[Unit]
Description=CheeseWAF
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=cheesewaf
Group=cheesewaf
ExecStart=/usr/local/bin/cheesewaf serve --config /etc/cheesewaf/cheesewaf.yaml
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=5s
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/var/lib/cheesewaf /var/log/cheesewaf
LimitNOFILE=1048576

[Install]
WantedBy=multi-user.target
